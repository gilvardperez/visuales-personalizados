{
  "dataRoles": [
    {
      "name": "value",
      "displayName": "Value",
      "kind": "Measure"
    },
    {
      "name": "comparison",
      "displayName": "Comparison",
      "kind": "Measure"
    },
    {
      "name": "trend",
      "displayName": "Trend",
      "kind": "Grouping"
    },
    {
      "name": "trendValues",
      "displayName": "Trend Values",
      "kind": "Measure"
    },
    {
      "name": "trendComparison",
      "displayName": "Trend Comparison",
      "kind": "Measure"
    }
  ],
  "objects": {
    "kpiStyle": {
      "displayName": "KPI Style",
      "properties": {
        "kpiVariant": {
          "displayName": "Variant",
          "type": {
            "enumeration": [
              { "value": "default" },
              { "value": "area" },
              { "value": "bars" },
              { "value": "progress" },
              { "value": "bullet" },
              { "value": "donut" },
              { "value": "gauge" },
              { "value": "comparison" }
            ]
          }
        },
        "labelPosition": {
          "displayName": "Label position",
          "type": {
            "enumeration": [
              { "value": "top" },
              { "value": "bottom" }
            ]
          }
        }
      }
    },
    "theme": {
      "displayName": "Theme",
      "properties": {
        "theme": {
          "displayName": "Theme",
          "type": {
            "enumeration": [
              { "value": "light" },
              { "value": "dark" },
              { "value": "auto" }
            ]
          }
        },
        "transparentBackground": {
          "displayName": "Transparent background",
          "type": { "bool": true }
        }
      }
    },
    "cardStyle": {
      "displayName": "Card Style",
      "properties": {
        "cardStyle": {
          "displayName": "Card style",
          "type": {
            "enumeration": [
              { "value": "flat" },
              { "value": "bordered" },
              { "value": "accent-left" }
            ]
          }
        },
        "cornerRadius": { "displayName": "Corner radius", "type": { "numeric": true } },
        "accentColor": { "displayName": "Accent color", "type": { "fill": { "solid": { "color": true } } } },
        "borderColor": { "displayName": "Border color", "type": { "fill": { "solid": { "color": true } } } }
      }
    },
    "deltaStyle": {
      "displayName": "Delta Style",
      "properties": {
        "deltaBadgeStyle": {
          "displayName": "Delta badge style",
          "type": {
            "enumeration": [
              { "value": "text" },
              { "value": "badge" },
              { "value": "pill" }
            ]
          }
        },
        "deltaShowArrow": { "displayName": "Show arrow", "type": { "bool": true } }
      }
    },
    "colors": {
      "displayName": "Colors",
      "properties": {
        "valueColor": {
          "displayName": "Value",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "positiveColor": {
          "displayName": "Positive",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "negativeColor": {
          "displayName": "Negative",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "progressColor": {
          "displayName": "Progress",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "successColor": {
          "displayName": "Success",
          "type": { "fill": { "solid": { "color": true } } }
        }
      }
    },
    "text": {
      "displayName": "Text",
      "properties": {
        "valueFontSize": {
          "displayName": "Value font size",
          "type": { "formatting": { "fontSize": true } }
        },
        "labelFontSize": {
          "displayName": "Label font size",
          "type": { "formatting": { "fontSize": true } }
        },
        "displayUnits": {
          "displayName": "Display units",
          "type": {
            "enumeration": [
              { "value": "auto" },
              { "value": "thousands" },
              { "value": "millions" },
              { "value": "billions" }
            ]
          }
        },
        "decimalPlaces": {
          "displayName": "Decimal places",
          "type": { "numeric": true }
        }
      }
    },
    "miniChart": {
      "displayName": "Mini Chart",
      "properties": {
        "showLastValueLabel": { "displayName": "Show last value label", "type": { "bool": true } },
        "highlightLastPoint": { "displayName": "Highlight last point", "type": { "bool": true } },
        "highlightColor": { "displayName": "Highlight color", "type": { "fill": { "solid": { "color": true } } } },
        "chartHeight": { "displayName": "Chart height", "type": { "numeric": true } },
        "barColor": { "displayName": "Bar color", "type": { "fill": { "solid": { "color": true } } } },
        "lineColor": { "displayName": "Line color", "type": { "fill": { "solid": { "color": true } } } },
        "areaFillOpacity": { "displayName": "Area fill opacity", "type": { "numeric": true } },
        "useGradient": { "displayName": "Use gradient", "type": { "bool": true } }
      }
    },
    "titleSubtitle": {
      "displayName": "Title & Subtitle",
      "properties": {
        "showTitle": { "displayName": "Show title", "type": { "bool": true } },
        "titleText": { "displayName": "Title text", "type": { "text": true } },
        "titleFontSize": { "displayName": "Title font size", "type": { "numeric": true } },
        "deltaSuffix": { "displayName": "Delta suffix", "type": { "text": true } },
        "comparisonSuffix": { "displayName": "Comparison suffix", "type": { "text": true } },
        "showComparisonValue": { "displayName": "Show comparison value", "type": { "bool": true } }
      }
    },
    "bulletDonut": {
      "displayName": "Bullet/Donut",
      "properties": {
        "targetLineColor": { "displayName": "Target line color", "type": { "fill": { "solid": { "color": true } } } },
        "bulletGoodColor": { "displayName": "Bullet good color", "type": { "fill": { "solid": { "color": true } } } },
        "bulletMidColor": { "displayName": "Bullet mid color", "type": { "fill": { "solid": { "color": true } } } },
        "bulletBadColor": { "displayName": "Bullet bad color", "type": { "fill": { "solid": { "color": true } } } },
        "donutThickness": { "displayName": "Donut thickness", "type": { "numeric": true } },
        "gaugeMinValue": { "displayName": "Gauge min value", "type": { "numeric": true } },
        "gaugeMaxValue": { "displayName": "Gauge max value", "type": { "numeric": true } },
        "gaugeRedThreshold": { "displayName": "Gauge red threshold", "type": { "numeric": true } },
        "gaugeYellowThreshold": { "displayName": "Gauge yellow threshold", "type": { "numeric": true } }
      }
    }
  },
  "dataViewMappings": [
    {
      "conditions": [
        {
          "value": { "max": 1 },
          "comparison": { "max": 1 },
          "trend": { "max": 1 },
          "trendValues": { "max": 1 },
          "trendComparison": { "max": 1 }
        }
      ],
      "categorical": {
        "categories": {
          "for": { "in": "trend" },
          "dataReductionAlgorithm": { "top": {} }
        },
        "values": {
          "select": [
            { "bind": { "to": "value" } },
            { "bind": { "to": "comparison" } },
            { "bind": { "to": "trendValues" } },
            { "bind": { "to": "trendComparison" } }
          ]
        }
      }
    }
  ],
  "privileges": []
}
